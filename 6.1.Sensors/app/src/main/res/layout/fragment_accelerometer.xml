<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="#F0F4F8">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="📡 Accelerometer"
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="#1A202C"
        android:layout_marginBottom="16dp"/>

    <!-- Card Nilai X Y Z -->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="12dp"
        app:cardCornerRadius="10dp"
        app:cardElevation="3dp">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="NILAI SENSOR" android:textSize="11sp" android:textColor="#A0AEC0"
                android:layout_marginBottom="10dp"/>
            <TextView android:id="@+id/tvX" android:layout_width="wrap_content"
                android:layout_height="wrap_content" android:text="X: -" android:textSize="15sp"
                android:textColor="#E53E3E" android:layout_marginBottom="6dp"/>
            <TextView android:id="@+id/tvY" android:layout_width="wrap_content"
                android:layout_height="wrap_content" android:text="Y: -" android:textSize="15sp"
                android:textColor="#38A169" android:layout_marginBottom="6dp"/>
            <TextView android:id="@+id/tvZ" android:layout_width="wrap_content"
                android:layout_height="wrap_content" android:text="Z: -" android:textSize="15sp"
                android:textColor="#3182CE"/>
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- Card Kemiringan -->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="12dp"
        app:cardCornerRadius="10dp"
        app:cardElevation="3dp">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="KEMIRINGAN" android:textSize="11sp" android:textColor="#A0AEC0"
                android:layout_marginBottom="6dp"/>
            <TextView android:id="@+id/tvTilt" android:layout_width="wrap_content"
                android:layout_height="wrap_content" android:text="📱 Posisi Datar"
                android:textSize="22sp" android:textColor="#2D3748"/>
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- Card Shake -->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardCornerRadius="10dp"
        app:cardElevation="3dp">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="SHAKE DETECTION" android:textSize="11sp" android:textColor="#A0AEC0"
                android:layout_marginBottom="6dp"/>
            <TextView android:id="@+id/tvShake" android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Gerakkan HP untuk mendeteksi shake"
                android:textSize="15sp" android:textColor="#2D3748"/>
        </LinearLayout>
    </androidx.cardview.widget.CardView>

</LinearLayout>